# Alpha Deck -- environment template. Copy to `.env` (gitignored) and fill in your values.
# Docker Compose auto-loads `.env` from this directory and injects the vars below into the backend
# container. The local dev loop (uvicorn on the host) reads the same names from your shell env.

# --- The Anthropic API key for the LLM seams --------------------------------------------------------
# Used by the FLAG-explanation drafter (#59) and the narrative->chain drafter (S5, #62).
# FAIL-OPEN: with no key, both seams simply return nothing (no explanation / an empty draft) and the rest
# of the app is unaffected. Never commit the real key -- it lives only in `.env` (gitignored).
ANTHROPIC_API_KEY=

# --- The SEC EDGAR User-Agent (filing pulls) --------------------------------------------------------
# SEC etiquette REQUIRES a declared contact on every request. Format: "Name contact@email".
# Used by the Extract feature's live SEC pull; without it, live pulls are skipped (cached/seed data works).
ALPHADECK_USER_AGENT=Alpha Deck Research admin you@example.com

# --- OPTIONAL: the deployment tenant ----------------------------------------------------------------
# The tenant the Workbench writes/reads under. Defaults to the demo tenant if unset.
# ALPHADECK_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- OPTIONAL: the local dev-loop database ----------------------------------------------------------
# For uvicorn on the HOST only. Docker Compose IGNORES this and always uses its in-network Postgres
# (postgres:5432). Leave unset to use the default demo DB at localhost:5544.
# DATABASE_URL=postgresql://alphadeck:alphadeck@localhost:5544/alphadeck

# --- OPTIONAL: the operational LLM dials (typed in backend/domain/settings.py) ----------------------
# These override the baked-in defaults WITHOUT a code edit (the point of the Settings refactor). All
# optional; leave unset to use the defaults shown. Safe to tune: the LLM never sources a number (invariant
# #3), so a model swap changes only draft QUALITY, never a computed call. (Trust-validated call-engine dials
# live in CallConfig and are deliberately NOT env-overridable.)
# ALPHADECK_LLM_MODEL=claude-haiku-4-5-20251001          # FLAG-explanation drafter (fast/cheap)
# ALPHADECK_LLM_MAX_TOKENS=256
# ALPHADECK_LLM_TIMEOUT_S=10.0
# ALPHADECK_LLM_DECOMPOSE_MODEL=claude-sonnet-4-6        # narrative->chain drafter (reasoning-heavy)
# ALPHADECK_LLM_DECOMPOSE_MAX_TOKENS=2000
# ALPHADECK_LLM_DECOMPOSE_TIMEOUT_S=60.0
# ALPHADECK_ANTHROPIC_BASE_URL=                          # unset => the SDK default (api.anthropic.com)
