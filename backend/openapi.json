{
  "openapi": "3.1.0",
  "info": {
    "title": "Alpha Deck",
    "summary": "Decision-support call-assembler API (advisory only; the CallCard is recomputed on read).",
    "version": "0.0.0"
  },
  "paths": {
    "/theses": {
      "get": {
        "tags": [
          "theses"
        ],
        "summary": "List Theses",
        "operationId": "list_theses_theses_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ThesisSummary"
                  },
                  "type": "array",
                  "title": "Response List Theses Theses Get"
                }
              }
            }
          }
        }
      }
    },
    "/theses/{thesis_id}": {
      "get": {
        "tags": [
          "theses"
        ],
        "summary": "Get Thesis",
        "operationId": "get_thesis_theses__thesis_id__get",
        "parameters": [
          {
            "name": "thesis_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Thesis Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThesisDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/theses/{thesis_id}/call": {
      "get": {
        "tags": [
          "theses"
        ],
        "summary": "Get Call",
        "description": "Recompute the CallCard live at ``asof`` \u2014 a READ-ONLY path. The signal stream is re-derived\nfrom the bitemporal facts (no persisted firing layer), so a given ``asof`` is deterministic and a\nrefetch / as-of-slider scrub / poll writes nothing. The accountability ``calls`` log is written\nby the batch ``pipeline.run`` (the official call of record), never by this GET.",
        "operationId": "get_call_theses__thesis_id__call_get",
        "parameters": [
          {
            "name": "thesis_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Thesis Id"
            }
          },
          {
            "name": "asof",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "description": "as-of date; the call uses no data knowable after it",
              "title": "Asof"
            },
            "description": "as-of date; the call uses no data knowable after it"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallCardResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
